# Copy to `.env` and fill in. NEVER commit the real .env (see .gitignore).
# .env is read by backend/core/config.py via pydantic-settings.

# Runtime
ENVIRONMENT=dev

# --- Gemini (LLM + embeddings) ---
# Free-tier key from Google AI Studio. Used for parser/scam_text/explain + embeddings.
GEMINI_API_KEY=

# --- Supabase (Postgres + pgvector + storage) ---
# Connection string for migrations/queries, plus REST creds if using the supabase client.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Pexels (image seeding) ---
# Free API key from pexels.com/api. Used once by the image seeder.
PEXELS_API_KEY=

# Note: BVG/VBB transit API, OSM Overpass, and Nominatim are keyless (no secrets needed).
